{
  "name": "tanamao-hub",
  "version": "0.0.0",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "dev": "concurrently \"ng serve --port 4201\" \"wait-on http://localhost:4201 && cross-env NODE_ENV=development electron .\"",
    "dist": "ng build --base-href ./ && cross-env NODE_ENV=production electron-builder"
  },
  "build": {
    "appId": "com.tanamao.hub",
    "productName": "Tanamao Hub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/tanamao-hub/browser/**/*",
      "electron/**/*",
      "package.json",
      "public/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^24.13.3",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.4"
  }
}
